# Copy this file to .env and fill in real values. .env is gitignored - never
# commit real secrets.

# Neon PostgreSQL - pooled connection string (used by the app at runtime).
# In Neon dashboard: Connection Details → "Pooled connection" toggle ON.
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true"

# Neon PostgreSQL - direct (unpooled) connection string (used by Prisma migrations only).
# In Neon dashboard: Connection Details → "Pooled connection" toggle OFF.
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Long random string (32+ chars) used to sign session JWTs. Generate one with:
#   openssl rand -base64 32
# Never reuse the same value between dev/staging/production environments.
JWT_SECRET="replace-with-a-long-random-value-at-least-32-characters"

# Optional. Overrides the default seeded admin password ("ChangeMe123!") so
# that well-known default never has to be the real one anywhere this seed
# script runs. Leave unset for local/throwaway dev databases.
ADMIN_SEED_PASSWORD=""
